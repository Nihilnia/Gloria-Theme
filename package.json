	"publisher": "Nihil",
	"icon": "icon.jpg",
	"repository": {
		"type": "git",
		"url": "https://github.com/Nihilnia/Gloria-Theme"
	},
	"engines": {
		"vscode": "^1.33.0"
	},
	"extensionKind": [
		"ui"
	],
	"keywords": [
		"retro",
		"80s"
	],
	"categories": [
		"Themes"
	],
	"activationEvents": [
		"onCommand:gloria.enableNeon",
		"onCommand:gloria.disableNeon"
	],
	"main": "./src/extension.js",
	"contributes": {
		"themes": [
			{
				"label": "Gloria Theme",
				"uiTheme": "vs-dark",
				"path": "./themes/gloria-color-theme.json"
			}
		],
		"commands": [
			{
				"command": "gloria.enableNeon",
				"title": "Gloria: Enable Neon Dreams"
			},
			{
				"command": "gloria.disableNeon",
				"title": "Gloria: Disable Neon Dreams"
			}
		],
		"configuration": {
			"title": "Gloria",
			"properties": {
				"gloria.brightness": {
					"type": "number",
					"default": 0.45,
					"description": "Set the brightness value for the glow effect. 0.0 is fully transparent and 1.0 is fully bright"
				},
				"gloria.disableGlow": {
					"type": "boolean",
					"default": false,
					"description": "Disable the glow effect, but show Gloria editor chrome updates"
				}
			}
		}
	},
